# === AWS Bedrock Knowledge Base (ingest ทำ manual บน AWS Console) ===
AWS_KNOWLEDGE_BASE_ID=your-knowledge-base-id
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_KB_NUMBER_OF_RESULTS=5

# Ingest flow (manual บน AWS — ไม่ผ่าน backend):
# 1. Upload PDF ไป S3 bucket ที่ผูกกับ Knowledge Base
# 2. Sync data source บน Bedrock Knowledge Base console
# 3. AWS จะ chunk + embed (เช่น Cohere Embed Multilingual v3) ให้อัตโนมัติ
# 4. ตอน chat backend เรียก retrieve API เท่านั้น
# 5. ถ้า vector index ไม่ดึง chunk ที่มีในไฟล์ต้นฉบับ ให้เปิด source fallback:
AWS_KB_SOURCE_FALLBACK=true
AWS_KB_S3_BUCKET=med-knowledge-base-syd
AWS_KB_S3_KEY=med_knowledge.txt
